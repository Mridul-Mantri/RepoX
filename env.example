# Application
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:3000

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://repox:repox@localhost:5432/repox?schema=public

# Redis (locking + pub/sub + socket.io adapter)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_EXPIRES=7d
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_REFRESH_EXPIRES=30d

# Razorpay (test keys for dev)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Business rules
HOLD_MINUTES=10
AUCTION_MIN_INCREMENT=1000
LOT_MIN_INCREMENT=10000
ANTI_SNIPE_WINDOW_SECONDS=120
ANTI_SNIPE_EXTENSION_SECONDS=120

# Default fees (% of sale price) — DB FeeSetting rows override these
FEE_RETAIL=2.5
FEE_DEALER=1.5
FEE_ENTERPRISE=1.0
GST_PERCENT=18

# Fraud detection thresholds
FRAUD_HOLD_ATTEMPTS_PER_MIN=5
FRAUD_BID_ATTEMPTS_PER_MIN=20
